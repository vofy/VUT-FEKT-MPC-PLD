# Ignore everything
*

# Allow directories so Git can traverse
!*/

# Allow project files
!*/*.xpr

# Allow src directories and their contents (including nested dirs)
!*/src/*
!*/src/sim/**
!*/src/ip/
!*/src/ip/*/
!*/src/ip/*/*.xci

# Allow everything inside SOURCES folder
!SOURCES/**
!*/SOURCES/**

# Make sure .gitignore itself is tracked
!.gitignore