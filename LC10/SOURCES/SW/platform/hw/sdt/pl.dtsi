			xlnx,edk-iptype = "PERIPHERAL";
			xlnx,use-jtag-bscan = <1>;
			xlnx,interconnect = <2>;
			xlnx,use-cross-trigger = <0>;
			xlnx,trace-protocol = <1>;
			status = "okay";
			xlnx,use-config-reset = <0>;
			xlnx,trig-out-ports = <1>;
			xlnx,device = "xc7z010";
			xlnx,dbg-mem-access = <0>;
			xlnx,trace-clk-out-phase = <90>;
			xlnx,name = "mdm_0";
		};
	};
};
